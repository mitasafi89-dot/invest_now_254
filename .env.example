# ── Copy to .env and fill in real values. NEVER commit the real .env. ──

# Supabase Postgres connection string (use the Transaction Pooler URI, IPv4).
# Supabase -> Connect -> URI -> Transaction pooler.
# The DB password MUST be percent-encoded (e.g. '/' -> %2F, '@' -> %40, ',' -> %2C).
# Example shape:
# postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Secret used to sign/derive session tokens. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Server runtime
NODE_ENV=development
PORT=3000

# Session lifetime in days (optional, default 30)
SESSION_TTL_DAYS=30

# ── M-Pesa (Safaricom Daraja) — leave blank to use the built-in mock provider ──
# When all of these are set, the real STK-push provider is used instead of the mock.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Public base URL used to build the Daraja result callback (e.g. https://yourdomain.com)
PUBLIC_BASE_URL=
